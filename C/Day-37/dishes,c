//https://www.codechef.com/problems/ADADISH

#include <stdio.h>
#include <stdlib.h>

int cmp(const void *a, const void *b){
    return *(int*)b - *(int*)a;
}

int main() {
	int t;
	scanf("%d", &t);
	while(t--){
	    int n;
	    scanf("%d", &n);
	    int arr[n];
	    for (int i = 0; i<n; i++){
	        scanf("%d", &arr[i]);
	    }
	    qsort(arr, n, sizeof(int), cmp);
	    int sum1 = 0, sum2 = 0;
	    for (int i = 0; i<n; i++){
	        if (sum1 <= sum2){
	            sum1+=arr[i];
	        }else{
	            sum2 += arr[i];
	        }
	    }
	    int max = (sum1 > sum2) ? sum1 : sum2;
	    printf("%d\n", max);
	}
	return 0;
}

